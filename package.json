{
  "name": "portfolio",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "npx rimraf .next .turbo",
    "build": "next build",
    "dev": "next --turbopack",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.10",
    "nextra": "^4.6.1",
    "nextra-theme-blog": "^4.6.1",
    "react": "^19.2.7",
    "react-cusdis": "^2.1.3",
    "react-dom": "^19.2.7"
  },
  "prettier": {
    "arrowParens": "always",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "semi": false
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@vercel/speed-insights",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
